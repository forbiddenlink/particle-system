{
  "name": "particle-system",
  "version": "0.1.0",
  "private": true,
  "description": "Next-generation 3D particle system creator with WebGPU compute shaders and node-based visual editor",
  "author": "Nova Particles Team",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @nova-particles/web dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @nova-particles/core test",
    "preview": "pnpm --filter @nova-particles/web preview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
